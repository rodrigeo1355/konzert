# ─── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL usa PgBouncer (pooled) — para la app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/konzert?pgbouncer=true&schema=public"
# DIRECT_URL sin pooler — para migraciones Prisma
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/konzert?schema=public"

# ─── Next.js / Payload CMS ─────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"
PAYLOAD_SECRET="your-payload-secret-min-32-chars"

# ─── Redis (BullMQ) ────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Konzert <noreply@konzert.cl>"

# ─── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET="your-auth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_CONCURRENCY="3"
SCRAPER_CRON="0 */6 * * *"
ADMIN_ALERT_EMAIL="admin@konzert.cl"

# ─── Vercel ────────────────────────────────────────────────────────────────────
VERCEL_URL=""

# ─── Railway ───────────────────────────────────────────────────────────────────
RAILWAY_ENVIRONMENT=""
