# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/konzert?schema=public"

# ─── Next.js / Payload CMS ─────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"
PAYLOAD_SECRET="your-payload-secret-min-32-chars"

# ─── Redis (BullMQ) ────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Konzert <noreply@konzert.cl>"

# ─── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_CONCURRENCY="3"
SCRAPER_CRON="0 */6 * * *"

# ─── Vercel ────────────────────────────────────────────────────────────────────
VERCEL_URL=""

# ─── Railway ───────────────────────────────────────────────────────────────────
RAILWAY_ENVIRONMENT=""
